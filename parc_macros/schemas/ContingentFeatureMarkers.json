{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContingentFeatureMarkers",
  "description": "Schema for morphological realizations contingent on multiple features.",
  "type": "object",
  "required": ["kind", "markers"],
  "additionalProperties": false,
  "properties": {
    "source_path": {
      "type": "string",
      "description": "The file path from which this config was loaded."
    },
    "kind": {
      "type": "string",
      "enum": ["ContingentFeatureMarkers"]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of inflectional features this set expones."
    },
    "class_name": {
      "type": "string",
      "description": "The name of the lexical class feature (e.g. conjugation_class)."
    },
    "feature": {
      "type": "string",
      "description": "The name of the morphological feature."
    },
    "global_stage": {
      "type": "string",
      "description": "Allows specifying a default value for the 'stage' attribute."
    },
    "global_markers": {
      "type": "array",
      "items": {
        "$ref": "./FeatureMarkers.json#/definitions/marker"
      },
      "description": "A marker or list of markers applied to all forms in this paradigm."
    },
    "markers": {
      "oneOf": [
        {
          "type": "array",
          "description": "An array over feature vectors and their realizations.",
          "items": {
            "type": "object",
            "required": ["features", "realization"],
            "properties": {
              "features": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "The feature value vector specified for this marker group."
              },
              "realization": {
                "type": "array",
                "items": {
                  "$ref": "./FeatureMarkers.json#/definitions/marker"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Map of class names to their feature realizations.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "array",
                  "items": {
                    "$ref": "./FeatureMarkers.json#/definitions/marker"
                  }
                }
              ]
            }
          }
        }
      ]
    }
  },
  "anyOf": [
    {
      "required": ["features"]
    },
    {
      "required": ["class_name", "feature"]
    }
  ]
}
